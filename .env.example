# LLM keys
ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=

# Source database (Teradata trial / Vantage + BigQuery target)
DEFAULT_SOURCE_DATABASE=teradata
INPUT_DDL_DIALECT=teradata

# Teradata connection (ClearScape / trial cloud)
# TD_* is preferred; TERADATA_* is also supported for backward compatibility.
TD_HOST=your-teradata-host.env.trial.teradata.com
TD_PORT=1025
TD_USER=demo_user
TD_PASSWORD=
TD_DATABASE=demo_user
TD_SSLMODE=require

# Google Cloud / BigQuery (target for migration + reconciliation)
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=US
GCP_SOURCE_DATASET=migration_source
GCP_TARGET_DATASET=migration_target
# Optional: path to service account JSON (otherwise use gcloud ADC)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Run history is stored locally in metadata/accelerator.duckdb (DuckDB metadata only).
