# LLM keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Source database (DuckDB for local dev; switch to teradata when ready)
DEFAULT_SOURCE_DATABASE=duckdb
DUCKDB_SOURCE_PATH=data/source.duckdb

# Google Cloud / BigQuery (target + cloud source for reconciliation)
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=US
# Shared recon schemas: DuckDB source schema + BigQuery target dataset
GCP_SOURCE_DATASET=migration_source
GCP_TARGET_DATASET=migration_target
# Optional: path to service account JSON (otherwise use gcloud ADC)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Teradata connection (for later — ClearScape / Vantage Express)
# TD_HOST=127.0.0.1
# TD_USER=dbc
# TD_PASSWORD=dbc
# TD_DATABASE=dbc
# TD_SSLMODE=require
