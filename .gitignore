# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
src/*.egg-info/

# Virtual environments
.venv

# Secrets and logs
.env
*.log
credentials/*
!credentials/.gitkeep

# Generated migration outputs
src/target_files_migration/*
!src/target_files_migration/.gitkeep

# Generated synthetic data
src/synthetic_data_gen/*.csv

# Local DuckDB stores
metadata/*.duckdb
metadata/*.duckdb.wal
data/

# Reconciliation query result exports
reconciliation/source_results/*
!reconciliation/source_results/.gitkeep
reconciliation/target_results/*
!reconciliation/target_results/.gitkeep
reconciliation/comparison_results/*
!reconciliation/comparison_results/.gitkeep
reconciliation/reconciliation_report.md

# Regression test reports
test_results/*
!test_results/.gitkeep

# Generated migration documentation (regenerate with: uv run python -m documentation)
documentation/*
!documentation/.gitkeep

# Empty dirs for generated artifacts
src/synthetic_data_gen/.gitkeep

# React frontend
frontend/node_modules/
frontend/dist/
debug-*.log
